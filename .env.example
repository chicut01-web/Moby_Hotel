# Copia in .env.local e compila. NON committare .env.local.

# Supabase — Project URL e anon (public) key: lato client e server.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service_role key: SOLO lato server (mai esporre al client).
# Usata da script/admin in futuro. Non prefissare con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — email transazionali (predisposto, non usato nel sito pubblico v1).
RESEND_API_KEY=
# Email che riceve le notifiche di richiesta prenotazione.
BOOKING_NOTIFICATION_EMAIL=
